  <script>
    // Mobile menu toggle
    document.getElementById('mobileMenuBtn').addEventListener('click', function() {
      document.getElementById('mobileMenu').classList.toggle('hidden');
    });

    // Category selector - update savings display
    const savingsData = {
      car: { label: 'Car Insurance', amount: '504' },
      home: { label: 'Home Insurance', amount: '191' },
      energy: { label: 'Energy', amount: '287' },
      broadband: { label: 'Broadband', amount: '156' },
      credit: { label: 'Credit Cards', amount: '713' },
      loans: { label: 'Personal Loans', amount: '340' }
    };

    document.getElementById('categorySelect').addEventListener('change', function() {
      const data = savingsData[this.value];
      document.getElementById('categoryLabel').textContent = data.label;
      document.getElementById('savingsAmount').textContent = data.amount;
    });
  </script>

